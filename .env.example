# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-4

# Google Maps API Key (get from https://console.cloud.google.com/)
# Make sure to enable "Places API" in Google Cloud Console
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Supabase Configuration (get from https://supabase.com/)
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role Key (keep SECRET - only for server-side operations)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Image Search Services (for fetching restaurant images online)
# Choose at least one for optimal restaurant image fetching when discovering new locations

# SerpAPI - Google Images search (RECOMMENDED)
# Get free key from: https://serpapi.com/ (100 free searches/month)
SERPAPI_KEY=your-serpapi-key-here

# Bing Image Search API (Alternative)
# Get key from: https://www.microsoft.com/en-us/bing/apis/bing-image-search-api
BING_IMAGE_SEARCH_KEY=your-bing-image-search-key-here

# Unsplash - High-quality stock photos (Fallback)
# Get key from: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your-unsplash-access-key-here
